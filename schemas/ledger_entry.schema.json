{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ief.dev/schemas/ledger_entry.schema.json",
  "title": "IEF Ledger Entry",
  "description": "A single immutable entry in the Operations run ledger. Append-only. Corrections are new entries referencing the original.",
  "type": "object",
  "required": [
    "entry_id",
    "task_id",
    "run_id",
    "event_type",
    "sequence",
    "timestamp",
    "payload"
  ],
  "properties": {
    "entry_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this ledger entry. Also serves as the dedup key."
    },
    "task_id": {
      "type": "string",
      "format": "uuid",
      "description": "The task this entry belongs to"
    },
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "The run this entry belongs to. Use a sentinel value (e.g., null or empty) for task-level pre-run events."
    },
    "event_type": {
      "type": "string",
      "description": "Semantic type of the event. Operations recommends standard types; Protocol allows extension.",
      "enum": [
        "task_created",
        "task_assigned",
        "task_completed",
        "task_failed",
        "task_cancelled",
        "task_escalated",
        "task_blocked",
        "task_resumed",
        "run_prepared",
        "run_started",
        "run_completed",
        "run_failed",
        "run_cancelled",
        "progress",
        "checkpoint_created",
        "context_attached",
        "artifact_produced",
        "approval_requested",
        "approval_received",
        "review_requested",
        "review_completed",
        "ledger_correction"
      ]
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonically increasing sequence number within the run. Must be unique within a run."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event occurred"
    },
    "agent_id": {
      "type": ["string", "null"],
      "description": "Identity of the runner or agent that emitted this event"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "error", "critical"],
      "default": "info",
      "description": "Event severity level"
    },
    "payload": {
      "type": "object",
      "description": "Event-type-specific structured data",
      "additionalProperties": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "ArtifactRef-style references to evidence supporting this event"
    },
    "corrected_entry_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "If this is a correction event, the entry_id of the original event being corrected"
    },
    "dedupe_key": {
      "type": ["string", "null"],
      "description": "Optional dedupe key for idempotency. If provided, duplicate entries with the same key are rejected."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "event_type": { "const": "ledger_correction" } }
      },
      "then": {
        "required": ["corrected_entry_id"],
        "properties": {
          "corrected_entry_id": { "type": "string", "format": "uuid" },
          "payload": {
            "type": "object",
            "required": ["correction_reason"],
            "properties": {
              "correction_reason": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "task_failed" } }
      },
      "then": {
        "properties": {
          "severity": { "enum": ["error", "critical"] },
          "payload": {
            "type": "object",
            "required": ["reason"],
            "properties": {
              "reason": { "type": "string" },
              "error_details": { "type": "object" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "task_escalated" } }
      },
      "then": {
        "properties": {
          "severity": { "const": "critical" },
          "payload": {
            "type": "object",
            "required": ["escalation_reason"],
            "properties": {
              "escalation_reason": { "type": "string" },
              "escalated_to": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "approval_requested" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["approval_type", "requested_from"],
            "properties": {
              "approval_type": { "type": "string" },
              "requested_from": { "type": "string" },
              "context": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "approval_received" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["decision", "approved_by"],
            "properties": {
              "decision": { "enum": ["approved", "denied"] },
              "approved_by": { "type": "string" },
              "approval_timestamp": { "type": "string", "format": "date-time" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "review_completed" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["decision", "reviewer"],
            "properties": {
              "decision": { "enum": ["approved", "rejected", "rework"] },
              "reviewer": { "type": "string" },
              "review_timestamp": { "type": "string", "format": "date-time" },
              "comments": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "task_resumed" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["from_state"],
            "properties": {
              "from_state": { "type": "string" },
              "resolution": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
