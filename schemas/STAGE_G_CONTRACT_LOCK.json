{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ief.ecosystem/schemas/stage-g-contract-lock.json",
  "title": "Stage G Contract Lock",
  "description": "Machine-readable contract lock for IEF Stage G (G8 Hardening). Defines frozen boundaries, allowed/denied mutation paths, and dispatch control rules. No runtime logic. Specification only.",
  "type": "object",
  "required": [
    "schema_version",
    "stage",
    "slice",
    "status",
    "authority",
    "baseline",
    "frozen_at",
    "layer_boundaries",
    "dispatch_control_rules",
    "no_implicit_state_sources",
    "mutation_matrix",
    "hard_gates"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of this contract lock schema."
    },
    "stage": {
      "type": "string",
      "const": "G",
      "description": "IEF program stage identifier."
    },
    "slice": {
      "type": "string",
      "const": "G8-1",
      "description": "Stage G sub-slice identifier."
    },
    "status": {
      "type": "string",
      "enum": ["frozen", "amended", "superseded"],
      "description": "Current status of this contract lock entry."
    },
    "authority": {
      "type": "object",
      "required": ["type", "source_issue", "comment_id", "classification"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["program_controller_decision", "human_owner_decision"],
          "description": "Type of authority source."
        },
        "source_issue": {
          "type": "string",
          "description": "GitHub issue reference (owner/repo#number).",
          "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+#\\d+$"
        },
        "comment_id": {
          "type": "string",
          "description": "GitHub comment ID containing the decision."
        },
        "comment_url": {
          "type": "string",
          "format": "uri",
          "description": "Full URL to the GitHub comment."
        },
        "classification": {
          "type": "string",
          "enum": ["DISPATCH_AUTHORIZED", "DISPATCH_MODIFIED", "DISPATCH_DEFERRED"],
          "description": "Decision classification."
        }
      }
    },
    "baseline": {
      "type": "object",
      "required": ["repo", "branch", "commit_sha"],
      "additionalProperties": false,
      "properties": {
        "repo": {
          "type": "string",
          "description": "Target repository (owner/repo).",
          "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$"
        },
        "branch": {
          "type": "string",
          "description": "Base branch from which the working branch was created."
        },
        "commit_sha": {
          "type": "string",
          "description": "Full SHA of the baseline commit.",
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "frozen_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the freeze was established."
    },
    "deliverables": {
      "type": "array",
      "description": "List of file paths produced by this slice.",
      "items": {
        "type": "string",
        "description": "Relative file path within the repository."
      }
    },
    "layer_boundaries": {
      "type": "array",
      "description": "Frozen boundary definitions for each IEF layer.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["layer", "responsibilities", "constraints"],
        "additionalProperties": false,
        "properties": {
          "layer": {
            "type": "string",
            "enum": ["Program", "Operations", "Verification"],
            "description": "Layer name."
          },
          "responsibilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of responsibilities owned by this layer."
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Frozen constraints: what this layer must not do."
          }
        }
      }
    },
    "dispatch_control_rules": {
      "type": "array",
      "description": "Rules governing how dispatch decisions are made and enforced.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "rule_text", "classification"],
        "additionalProperties": false,
        "properties": {
          "rule_id": {
            "type": "string",
            "description": "Stable rule identifier.",
            "pattern": "^DCR-[0-9]+$"
          },
          "rule_text": {
            "type": "string",
            "description": "Human-readable rule statement."
          },
          "classification": {
            "type": "string",
            "enum": ["mandatory", "prohibitory"],
            "description": "Whether this rule requires or forbids an action."
          }
        }
      }
    },
    "no_implicit_state_sources": {
      "type": "object",
      "required": ["allowed_durable_sources", "prohibited_sources"],
      "additionalProperties": false,
      "properties": {
        "allowed_durable_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source_type", "format", "authority"],
            "additionalProperties": false,
            "properties": {
              "source_type": {
                "type": "string",
                "description": "Name of the durable source type."
              },
              "format": {
                "type": "string",
                "description": "Expected format or location."
              },
              "authority": {
                "type": "string",
                "description": "What kind of information this source is authoritative for."
              }
            }
          }
        },
        "prohibited_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source_type", "reason"],
            "additionalProperties": false,
            "properties": {
              "source_type": {
                "type": "string",
                "description": "Name of the prohibited source."
              },
              "reason": {
                "type": "string",
                "description": "Why this source is prohibited."
              }
            }
          }
        }
      }
    },
    "mutation_matrix": {
      "type": "array",
      "description": "Enumerated mutation paths with allow/deny classification.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "mutation_path", "classification"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "repository",
              "dispatch",
              "lifecycle",
              "ledger",
              "evidence"
            ],
            "description": "Mutation category."
          },
          "target_repo": {
            "type": "string",
            "description": "Target repository (owner/repo). Required for category=repository.",
            "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$"
          },
          "mutation_path": {
            "type": "string",
            "description": "Human-readable description of the mutation action."
          },
          "classification": {
            "type": "string",
            "enum": ["ALLOWED", "ALLOWED_GATED", "DENIED"],
            "description": "Access classification."
          },
          "gate_requirement": {
            "type": "string",
            "description": "Description of the gate required for ALLOWED_GATED."
          },
          "notes": {
            "type": "string",
            "description": "Additional context or constraints."
          }
        }
      }
    },
    "hard_gates": {
      "type": "array",
      "description": "Absolute prohibitions for the duration of Stage G.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gate_id", "gate_text"],
        "additionalProperties": false,
        "properties": {
          "gate_id": {
            "type": "string",
            "description": "Stable gate identifier.",
            "pattern": "^HG-[0-9]+$"
          },
          "gate_text": {
            "type": "string",
            "description": "Human-readable gate statement."
          }
        }
      }
    },
    "amendment_process": {
      "type": "object",
      "description": "Process for modifying this frozen contract lock.",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step_number", "description"],
            "additionalProperties": false,
            "properties": {
              "step_number": {
                "type": "integer",
                "minimum": 1
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
